#!/usr/bin/env python3

import json
import sys
import subprocess

class App(object):
    def __init__(self):
        self.match = None

    def activate(self, index):
        if not self.matches:
            return
        
        with subprocess.Popen(['xclip', '-selection', 'clipboard'], stdin=subprocess.PIPE) as process:
            process.stdin.write(self.matches[index].encode())
            process.stdin.close()

        sys.stdout.write('"Close"\n')
        sys.stdout.flush()

    def search_word(self, query):
        command = f'echo {query} | aspell -a | tail -n +2'
        response = subprocess.run(command, shell=True, text=True, capture_output=True).stdout

        startLocation = response.find(":") + 1
        response = response[startLocation:]

        response = '\n'.join([s for s in response.splitlines() if s]).replace(', ', ' ')
        result = response.split()

        if '*' in result:
            result = [query]

        if '0' in result:
            result = ["No match found"]
            
        return result

    def search(self, query):
        query = query.split(' ', 1)[1]
        self.matches = self.search_word(query)

        for index, word in enumerate(self.matches):
            sys.stdout.write(json.dumps({
                'Append': {
                    'id': index,
                    'name': word,
                    'description': f'Spell check: {query}',
                    'keywords': None,
                    'icon': None,
                    'exec': None,
                    'window': None
                }
            }))
            sys.stdout.write('\n')

        sys.stdout.write('"Finished"\n')
        sys.stdout.flush()

def main():
    app = App()

    for line in sys.stdin:
        try:
            request = json.loads(line)
            if 'Search' in request:
                app.search(request['Search'])
            elif 'Activate' in request:
                app.activate(request['Activate'])
        except json.decoder.JSONDecodeError:
            pass

if __name__ == '__main__':
    main()
